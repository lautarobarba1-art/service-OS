# Supabase local: `supabase start` expone Postgres normalmente en 127.0.0.1:54322.
# Nunca apuntar esta variable a la base de producción.
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Solo para una base remota descartable creada exclusivamente para tests.
ALLOW_REMOTE_TEST_DATABASE=false
PUBLIC_RATE_LIMIT_SECRET=integration-test-secret-at-least-32-characters
